{
  "alwaysThinkingEnabled": true,
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "YOUR_API_TOKEN_HERE",
    "ANTHROPIC_BASE_URL": "https://api.minimaxi.com/anthropic",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "MiniMax-M2.5-highspeed",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "MiniMax-M2.5-highspeed",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "MiniMax-M2.5-highspeed",
    "ANTHROPIC_MODEL": "MiniMax-M2.5-highspeed",
    "ANTHROPIC_REASONING_MODEL": "MiniMax-M2.5-highspeed",
    "API_TIMEOUT_MS": "3000000"
  },
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(yarn *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(python3 *)",
      "Bash(pip3 *)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Bash(npx *)",
      "Bash(pnpx *)",
      "Bash(bunx *)",
      "Bash(yarn dlx *)",
      "Bash(cargo *)",
      "Bash(cargo build *)",
      "Bash(cargo run *)",
      "Bash(cargo test *)",
      "Bash(cargo clippy *)",
      "Bash(go get *)",
      "Bash(go mod *)",
      "Bash(go build *)",
      "Bash(go run *)",
      "Bash(go test *)",
      "Bash(go vet *)",
      "Bash(pip install *)",
      "Bash(pip uninstall *)",
      "Bash(pip freeze *)",
      "Bash(pip list *)",
      "Bash(pip show *)",
      "Bash(pip check *)",
      "Bash(python3 -m *)",
      "Bash(uv *)",
      "Bash(uv pip *)",
      "Bash(uv venv *)",
      "Bash(uv sync *)",
      "Bash(uv run *)",
      "Bash(uv add *)",
      "Bash(uv remove *)",
      "Bash(uv tree *)",
      "Bash(uv lock *)",
      "Bash(uv lockfile *)",
      "Bash(uv pip list *)",
      "Bash(uv pip freeze *)",
      "Bash(uv pip show *)",
      "Bash(uv pip check *)",
      "Bash(uvx *)",
      "Bash(make *)",
      "Bash(cmake *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(git checkout -b *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git cherry-pick *)",
      "Bash(git revert *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(top)",
      "Bash(ps *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(tar *)",
      "Bash(unzip *)",
      "Bash(zip *)",
      "Bash(docker ps)",
      "Bash(docker images)",
      "Bash(docker compose *)",
      "Bash(docker build *)",
      "Bash(docker pull *)",
      "Read(~/.zshrc)",
      "Read(~/.bashrc)",
      "Read(~/.gitconfig)",
      "Read(~/.npmrc)",
      "Read(~/.pnpmrc)",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm -d *)",
      "Bash(rm *)",
      "Bash(cp -r *)",
      "Bash(mv *)",
      "Write",
      "Edit",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd)",
      "Bash(sudo *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(chown -R *)",
      "Bash(chmod -R 777 *)",
      "Bash(docker run *)",
      "Bash(docker stop *)",
      "Bash(docker rm *)",
      "Bash(docker rmi *)",
      "Bash(docker exec *)",
      "Bash(docker system prune *)"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(./secrets/**)",
      "Read(./credentials/**)",
      "Read(./config/credentials.json)",
      "Read(./**/credentials.json)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./id_rsa*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.npm/_authToken)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(sftp *)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git push --force-with-lease)",
      "Bash(git push -f *)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Bash(yarn publish *)",
      "Bash(cargo publish *)",
      "Bash(go publish *)",
      "Bash(gem push *)",
      "Bash(pip upload *)",
      "Bash(curl -X POST *api*)",
      "Bash(wget *password*)",
      "Bash(mkfs.*)",
      "Bash(dd *)",
      "Bash(eval *)",
      "Bash(base64 -d *)"
    ],
    "disableBypassPermissionsMode": "disable"
  }
}